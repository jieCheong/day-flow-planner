# PostgreSQL connection string
# Neon:    postgresql://user:pass@ep-xxx.neon.tech/dayflow?sslmode=require
# Railway: postgresql://postgres:pass@host.railway.app:5432/railway
DATABASE_URL=postgresql://user:password@host:5432/dayflow

# Secret used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET=your-long-random-secret-here

# Your deployed frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

PORT=8787
